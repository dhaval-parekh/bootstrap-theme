{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bootstrap/card",
	"version": "1.0.0",
	"title": "Card (Bootstrap)",
	"category": "common",
	"icon": "format-aside",
	"description": "Bootstrap 5 Card Component",
	"attributes": {
		"textAlign": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false,
		"align": true,
		"spacing": {
			"margin": true,
			"padding": false
		}
	},
	"textdomain": "bootstrap-theme",
	"editorScript": "file:./index.js"
}
