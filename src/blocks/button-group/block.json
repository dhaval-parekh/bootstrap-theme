{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bootstrap/button-group",
	"version": "1.0.0",
	"title": "Button Group (Bootstrap)",
	"category": "common",
	"icon": "button",
	"description": "Bootstrap 5 Button Group Component",
	"attributes": {
		"size": {
			"type": "string",
			"default": ""
		},
		"vertical": {
			"type": "boolean",
			"default": false
		},
		"ariaLabel": {
			"type": "string",
			"default": "Button group"
		}
	},
	"supports": {
		"html": false,
		"spacing": {
			"margin": true,
			"padding": false
		}
	},
	"textdomain": "bootstrap-theme",
	"editorScript": "file:./index.js"
}
