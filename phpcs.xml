<?xml version="1.0"?>
<ruleset name="WordPress Coding Standards">
	<rule ref="PHPCompatibilityWP"/>
	<rule ref="WordPress-VIP-Go"/>
	<rule ref="WordPress-Extra"/>
	<rule ref="WordPress-Docs"/>
	<rule ref="Travelopia-WordPress"/>

	<!-- How to scan. -->
	<arg value="sp"/> <!-- Show sniff and progress -->
	<arg name="colors"/> <!-- Show results with colors. Disable if working on Windows -->
	<arg name="basepath" value="."/> <!-- Strip the file paths down to the relevant bit -->
	<arg name="parallel" value="8"/> <!-- Enables parallel processing when available for faster results -->
	<arg name="extensions" value="php,js"/> <!-- Limit to PHP and JS files -->

	<!-- What not to scan. -->
	<exclude-pattern>./wordpress</exclude-pattern>
	<exclude-pattern>./build</exclude-pattern>
	<exclude-pattern>./vendor</exclude-pattern>

	<rule ref="WordPress.NamingConventions.ValidVariableName">
		<properties>
			<property name="allowed_custom_properties" type="array">
				<element value="tagName"/>
				<element value="textContent"/>
				<element value="nextSibling"/>
				<element value="parentNode"/>
			</property>
		</properties>
	</rule>

	<!--@see https://github.com/WordPress/WordPress-Coding-Standards/issues/2035#issuecomment-1325532520-->
	<ini name="error_reporting" value="E_ALL &#38; ~E_DEPRECATED"/>

	<!-- Check up to 20 files simultaneously. -->
	<arg name="parallel" value="20"/>
</ruleset>
