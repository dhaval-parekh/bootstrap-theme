{
	"$schema": "https:\/\/schemas.wp.org\/trunk\/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"custom": true,
			"customGradient": true,
			"link": true,
			"palette": [
				{
					"name": "Primary",
					"slug": "primary",
					"color": "#0d6efd"
				},
				{
					"name": "Secondary",
					"slug": "secondary",
					"color": "#6c757d"
				},
				{
					"name": "Success",
					"slug": "success",
					"color": "#198754"
				},
				{
					"name": "Info",
					"slug": "info",
					"color": "#0dcaf0"
				},
				{
					"name": "Warning",
					"slug": "warning",
					"color": "#ffc107"
				},
				{
					"name": "Danger",
					"slug": "danger",
					"color": "#dc3545"
				},
				{
					"name": "Light",
					"slug": "light",
					"color": "#f8f9fa"
				},
				{
					"name": "Dark",
					"slug": "dark",
					"color": "#212529"
				}
			]
		},
		"typography": {
			"customFontSize": true,
			"defaultFontSizes": true,
			"fontSizes": [
				{
					"name": "Small",
					"slug": "small",
					"size": "0.875rem"
				},
				{
					"name": "Medium",
					"slug": "medium",
					"size": "1rem"
				},
				{
					"name": "Large",
					"slug": "large",
					"size": "1.25rem"
				},
				{
					"name": "Extra Large",
					"slug": "extra-large",
					"size": "1.5rem"
				},
				{
					"name": "H1",
					"slug": "h1",
					"size": "calc(1.375rem + 1.5vw)"
				},
				{
					"name": "H2",
					"slug": "h2",
					"size": "calc(1.325rem + 0.9vw)"
				},
				{
					"name": "H3",
					"slug": "h3",
					"size": "calc(1.3rem + 0.6vw)"
				},
				{
					"name": "H4",
					"slug": "h4",
					"size": "calc(1.275rem + 0.3vw)"
				}
			]
		},
		"spacing": {
			"units": [
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			],
			"spacingSizes": [
				{
				}
			]
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"textDecoration": "none"
				}
			},
			"core/button": {
				"border": {
					"radius": "0.375rem"
				},
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--light)"
				},
				"typography": {
					"fontWeight": "400"
				}
			}
		},
		"layout": {
			"contentSize": "840px",
			"wideSize": "1100px"
		}
	}
}
