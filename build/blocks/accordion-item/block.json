{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "bootstrap/accordion-item",
  "version": "1.0.0",
  "title": "Accordion Item (Bootstrap)",
  "category": "common",
  "icon": "minus",
  "description": "Bootstrap 5 Accordion Item",
  "parent": [
    "bootstrap/accordion"
  ],
  "attributes": {
    "title": {
      "type": "string",
      "default": ""
    },
    "blockId": {
      "type": "string",
      "default": ""
    },
    "expanded": {
      "type": "boolean",
      "default": false
    }
  },
  "usesContext": [
    "bootstrap/accordion/blockId",
    "bootstrap/accordion/alwaysOpen"
  ],
  "supports": {
    "html": false
  },
  "textdomain": "bootstrap-theme",
  "editorScript": "file:./index.js"
}